async function getTweetEvents(filters: SituationFilters): Promise<FeedItem[]> {
  const where: Prisma.TweetWhereInput = {
    analysisStatus: 'done',
    createdAt: {
      gte: filters.fechaDesde ? new Date(filters.fechaDesde) : subHours(new Date(), 24),
      lte: filters.fechaHasta ? new Date(filters.fechaHasta) : new Date(),
    },
    // Filtro por lugar si está activo
    ...(filters.lugaresIds.length ? {
      analysis: {
        geoRefs: { path: '$[*].nombre', array_contains: filters.lugaresIds }
      }
    } : {}),
    // Filtro por score de impacto
    ...(filters.soloHechosCentrales ? {
      analysis: { impactoPotencial: { in: ['alto', 'critico'] } }
    } : {}),
  };

  const tweets = await prisma.tweet.findMany({
    where,
    include: { profile: true, analysis: true },
    orderBy: { createdAt: 'desc' },
    take: 100,
  });

  return tweets.map(tweet => ({
    type: 'tweet' as const,
    timestamp: tweet.createdAt.toISOString(),
    data: normalizeTweetForFeed(tweet),
  }));
}


function normalizeTweetForFeed(tweet: TweetWithRelations): FeedTweet {
  const analysis = tweet.analysis;
  return {
    // Metadata del contenido
    id: tweet.id,
    type: 'tweet',
    content: tweet.rawContent,
    url: tweet.url,
    timestamp: tweet.createdAt.toISOString(),

    // Perfil del autor
    author: {
      username: tweet.profile.username,
      displayName: tweet.profile.displayName || tweet.profile.username,
      tier: tweet.profile.tier,
      category: tweet.profile.category,
      verifiedType: tweet.profile.verifiedType,
      profileImageUrl: tweet.profile.profileImageUrl,
      isStateAffiliated: tweet.profile.isStateAffiliated,
      actorNetworkSlug: tweet.profile.actorNetworkSlug,
