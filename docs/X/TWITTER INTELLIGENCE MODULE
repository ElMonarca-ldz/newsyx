// /src/routes/admin/twitter.ts

// GET /api/admin/twitter/pool-health
router.get('/pool-health', adminAuth, async (req, res) => {
  const cached = await redis.get('twitter:pool:health');
  if (cached) return res.json(JSON.parse(cached));
  res.json({ error: 'No health data available yet' });
});

// POST /api/admin/twitter/relogin-failed
router.post('/relogin-failed', adminAuth, async (req, res) => {
  // Encolar tarea Celery de relogin
  await celery.send('tasks.twitter_scraper.relogin_failed_accounts');
  res.json({ ok: true });
});

// GET /api/admin/twitter/profiles
router.get('/profiles', adminAuth, async (req, res) => {
  const profiles = await prisma.twitterProfile.findMany({
    orderBy: [{ tier: 'asc' }, { username: 'asc' }],
    include: {
      _count: { select: { tweets: true } },
      tweets: {
        where: { analysisStatus: 'pending' },
        select: { id: true },
      }
    }
  });
  res.json(profiles);
});

// POST /api/admin/twitter/profiles
router.post('/profiles', adminAuth, async (req, res) => {
  const data = createProfileSchema.parse(req.body);
  const profile = await prisma.twitterProfile.create({ data });
  res.json(profile);
});

// PATCH /api/admin/twitter/profiles/:id
router.patch('/profiles/:id', adminAuth, async (req, res) => {
  const data = updateProfileSchema.parse(req.body);
  const profile = await prisma.twitterProfile.update({
    where: { id: req.params.id },
    data,
  });
  res.json(profile);
});

// POST /api/admin/twitter/profiles/:id/scrape-now
router.post('/profiles/:id/scrape-now', adminAuth, async (req, res) => {
  // Forzar scrape inmediato con prioridad máxima
  await celery.send('tasks.twitter_scraper.scrape_profile_tweets',
    [req.params.id], { priority: 0, queue: 'twitter_scrape' }
  );
  res.json({ ok: true, message: 'Scrape encolado con prioridad máxima' });
});
