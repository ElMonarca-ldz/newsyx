### 1.3 · Scrape Tasks (Celery)

```python
# /ai_engine/tasks/twitter_scraper.py
import asyncio
from datetime import datetime, timedelta
from contextlib import aclosing
from celery import shared_task
from twscrape import gather
from app.services.twitter.account_pool import pool_manager
from app.db import prisma
from app.redis_client import redis
import logging, json

logger = logging.getLogger(__name__)

# ─── Intervalos por tier ──────────────────────────────────────────────
TIER_INTERVALS = {
    "S": 5,   # Organismos oficiales (BCRA, Presidencia, etc.)
    "A": 10,  # Políticos y funcionarios
    "B": 15,  # Periodistas y medios
    "C": 30,  # Economistas y analistas
}

TWEETS_PER_SCRAPE = 20  # máximo por sesión de scraping por perfil


@shared_task(bind=True, max_retries=3, default_retry_delay=300)
def scrape_profile_tweets(self, profile_id: str):
    """
    Scrape tweets de un perfil y encolar para análisis.
    Se programa dinámicamente desde el scheduler según el tier.
    """
    asyncio.run(_scrape_profile_tweets_async(self, profile_id))


async def _scrape_profile_tweets_async(task, profile_id: str):
    profile = await prisma.twitterprofile.find_unique(where={"id": profile_id})
    if not profile or not profile.scrapeEnabled:
        return

    await pool_manager.initialize()

    try:
        # Resolver xUserId si no lo tenemos (solo primera vez)
        if not profile.xUserId:
            user = await pool_manager.api.user_by_login(profile.username)
            if not user:
                logger.warning(f"[Scraper] User not found: @{profile.username}")
                return
            await prisma.twitterprofile.update(
                where={"id": profile_id},
                data={"xUserId": str(user.id), "displayName": user.displayName,
                      "followersCount": user.followersCount,
                      "verifiedType": str(user.blue) if user.blue else None}
            )
            profile.xUserId = str(user.id)

        # Obtener tweets nuevos (desde el último ID conocido)
        new_tweets = []
        since_id = int(profile.lastTweetId) if profile.lastTweetId else None

        async with aclosing(
            pool_manager.api.user_tweets(int(profile.xUserId), limit=TWEETS_PER_SCRAPE)
        ) as gen:
            async for tweet in gen:
                # Parar si llegamos a tweets ya procesados
                if since_id and tweet.id <= since_id:
                    break

                # Filtros de calidad
                if not _passes_quality_filters(tweet, profile):
                    continue

                new_tweets.append(tweet)

        if not new_tweets:
            logger.debug(f"[Scraper] No new tweets for @{profile.username}")
            return

        # Persistir en DB (upsert para evitar duplicados)
        saved_count = 0
        for tweet in new_tweets:
            try:
                await prisma.tweet.upsert(
                    where={"id": str(tweet.id)},
                    create=_tweet_to_prisma(tweet, profile_id),
                    update={"likeCount": tweet.likeCount,
                            "retweetCount": tweet.retweetCount,
                            "viewCount": tweet.viewCount},
                )
                saved_count += 1
            except Exception as e:
                logger.error(f"[Scraper] Error saving tweet {tweet.id}: {e}")

        # Actualizar cursor y stats del perfil
        if new_tweets:
            await prisma.twitterprofile.update(
                where={"id": profile_id},
                data={
                    "lastTweetId": str(new_tweets[0].id),  # más reciente
                    "lastScrapedAt": datetime.utcnow(),
                    "consecutiveFails": 0,
                }
            )

        logger.info(f"[Scraper] @{profile.username}: {saved_count} new tweets saved")

        # Publicar en Redis → WebSocket → Frontend (breaking tweets de tier S/A)
        if profile.tier in ("S", "A") and new_tweets:
            for tweet in new_tweets[:3]:  # máximo 3 por perfil por ciclo
                await _publish_breaking_tweet(tweet, profile)

    except Exception as exc:
        # Incrementar fail counter
        await prisma.twitterprofile.update(
            where={"id": profile_id},
            data={"consecutiveFails": {"increment": 1}}
        )

        logger.error(f"[Scraper] Error scraping @{profile.username}: {exc}")

        # Reintentar con backoff
        raise task.retry(exc=exc, countdown=60 * (task.request.retries + 1))


def _passes_quality_filters(tweet, profile) -> bool:
    """Filtros de calidad antes de persistir."""
    # Filtrar retweets si no está configurado
    if tweet.retweetedTweet and not profile.scrapeRTs:
        return False
    # Filtrar replies si no está configurado
    if tweet.inReplyToTweetId and not profile.scrapeReplies:
        return False
    # Longitud mínima
    if len(tweet.rawContent) < profile.minTweetLength:
        return False
    # Solo español o indefinido (para perfiles LATAM)
    if tweet.lang and tweet.lang not in ("es", "und"):
        return False
    return True


def _tweet_to_prisma(tweet, profile_id: str) -> dict:
    """Convierte modelo twscrape.Tweet a dict para Prisma."""
    return {
        "id": str(tweet.id),
        "profileId": profile_id,
        "rawContent": tweet.rawContent,
        "lang": tweet.lang,
        "createdAt": tweet.date,
        "url": tweet.url,
        "likeCount": tweet.likeCount or 0,
        "retweetCount": tweet.retweetCount or 0,
        "replyCount": tweet.replyCount or 0,
        "quoteCount": tweet.quoteCount or 0,
        "viewCount": tweet.viewCount,
        "isRetweet": bool(tweet.retweetedTweet),
        "isReply": bool(tweet.inReplyToTweetId),
        "isQuote": bool(tweet.quotedTweet),
        "quotedTweetId": str(tweet.quotedTweet.id) if tweet.quotedTweet else None,
        "inReplyToId": str(tweet.inReplyToTweetId) if tweet.inReplyToTweetId else None,
        "hasMedia": bool(tweet.media),
        "analysisStatus": "pending",
    }


async def _publish_breaking_tweet(tweet, profile):
    """Publica tweet relevante al WebSocket para alert inmediata."""
    await redis.publish("situation_monitor:alerts", json.dumps({
        "type": "new_tweet",
        "payload": {
            "tweet_id": str(tweet.id),
            "username": profile.username,
            "display_name": profile.displayName or profile.username,
            "tier": profile.tier,
            "category": profile.category,
            "content_preview": tweet.rawContent[:120],
            "url": tweet.url,
            "timestamp": tweet.date.isoformat(),
        }
    }))
