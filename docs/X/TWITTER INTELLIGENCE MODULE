      retweets: tweet.retweetCount,
      replies: tweet.replyCount,
      views: tweet.viewCount,
    },

    // Análisis (si está disponible)
    analysis: analysis ? {
      intencion: analysis.intencion,
      esDeclaracionOficial: analysis.esDeclaracionOficial,
      impactoPotencial: analysis.impactoPotencial,
      sentimientoLabel: analysis.sentimientoLabel,
