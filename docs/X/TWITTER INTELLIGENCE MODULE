### 1.4 · Scheduler Dinámico (Celery Beat)

```python
# /ai_engine/tasks/twitter_scheduler.py
"""
En lugar de configurar Celery Beat estáticamente,
este scheduler corre cada minuto y decide qué perfiles
deben ser scrapeados en este ciclo según su tier e
intervalo configurado.
"""
from celery import shared_task
from datetime import datetime, timedelta
from app.db import prisma
from .twitter_scraper import scrape_profile_tweets
import logging

logger = logging.getLogger(__name__)

TIER_INTERVALS = {"S": 5, "A": 10, "B": 15, "C": 30}


@shared_task
def dispatch_scrape_jobs():
    """
    Corre cada minuto (configurado en Celery Beat).
    Determina qué perfiles necesitan ser scrapeados y
    los encola con la prioridad correcta.
    """
    import asyncio
    asyncio.run(_dispatch_async())


async def _dispatch_async():
    now = datetime.utcnow()

    # Traer todos los perfiles activos
    profiles = await prisma.twitterprofile.find_many(
        where={"scrapeEnabled": True, "isActive": True, "consecutiveFails": {"lt": 5}}
    )

    dispatched = 0
    for profile in profiles:
        interval_min = profile.scrapeInterval or TIER_INTERVALS.get(profile.tier, 30)
        next_scrape = (profile.lastScrapedAt or datetime.min) + timedelta(minutes=interval_min)

        if now >= next_scrape:
            # Prioridad Celery: menor número = mayor prioridad
            priority = {"S": 1, "A": 3, "B": 5, "C": 7}.get(profile.tier, 5)
            scrape_profile_tweets.apply_async(
                args=[profile.id],
                priority=priority,
                queue="twitter_scrape",
            )
            dispatched += 1

    if dispatched:
        logger.info(f"[Scheduler] Dispatched {dispatched} scrape jobs")


