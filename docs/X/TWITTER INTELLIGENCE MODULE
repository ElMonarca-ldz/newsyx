```python
# /ai_engine/tasks/tweet_analyzer.py
from celery import shared_task
from datetime import datetime
import json, logging
from app.db import prisma
from app.services.llm import call_gemini
from app.services.nlp import spacy_ner, pysentimiento_analyze

logger = logging.getLogger(__name__)

BATCH_SIZE = 10  # tweets a analizar por ciclo


@shared_task
def analyze_pending_tweets():
    """Analiza tweets pendientes en lotes. Corre cada 2 minutos."""
    import asyncio
    asyncio.run(_analyze_pending_async())


async def _analyze_pending_async():
    # Traer tweets pendientes ordenados por tier del perfil (S primero)
    pending = await prisma.tweet.find_many(
        where={"analysisStatus": "pending"},
        include={"profile": True},
        order_by=[
            {"profile": {"tier": "asc"}},  # S < A < B < C alfabéticamente
            {"createdAt": "desc"},
        ],
        take=BATCH_SIZE,
    )

    if not pending:
        return

    for tweet in pending:
        await _analyze_single_tweet(tweet)


async def _analyze_single_tweet(tweet):
    try:
        # Marcar como procesando
        await prisma.tweet.update(
            where={"id": tweet.id},
            data={"analysisStatus": "processing"}
        )

        profile = tweet.profile

        # ─── spaCy NER rápido ─────────────────────────────────
        entities_spacy = spacy_ner(tweet.rawContent)

        # ─── pysentimiento ────────────────────────────────────
        sentiment = pysentimiento_analyze(tweet.rawContent)

        # ─── LLM (Gemini Flash) ───────────────────────────────
        prompt = build_tweet_prompt(tweet, profile)
        llm_result = await call_gemini(prompt, max_tokens=800)
        analysis = json.loads(llm_result)

        # ─── Merge NLP + LLM ──────────────────────────────────
        # pysentimiento overrides LLM si confianza > 0.8
        if sentiment["confidence"] > 0.8:
            analysis["sentimientoLabel"] = sentiment["label"]
            analysis["sentimientoScore"] = sentiment["score"]

        # ─── Persistir ───────────────────────────────────────
        await prisma.tweetanalysis.upsert(
            where={"tweetId": tweet.id},
            create={
                "tweetId": tweet.id,
                "intencion": analysis.get("intencion", "informar"),
                "esDeclaracionOficial": analysis.get("es_declaracion_oficial", False),
                "impactoPotencial": analysis.get("impacto_potencial", "bajo"),
                "sentimientoLabel": analysis.get("sentimientoLabel", "NEU"),
                "sentimientoScore": analysis.get("sentimientoScore", 0.5),
                "scoreAlarmismo": analysis.get("scoreAlarmismo", 0.0),
                "esOpinion": analysis.get("es_opinion", False),
                "verificabilidad": analysis.get("verificabilidad", "opinion"),
                "resumen": analysis.get("resumen", ""),
                "keywords": json.dumps(analysis.get("keywords", [])),
                "entidades": json.dumps(analysis.get("entidades", [])),
                "geoRefs": json.dumps(analysis.get("geo_refs", [])),
                "actoresRef": json.dumps(analysis.get("actores_ref", [])),
                "tagsItl": json.dumps(analysis.get("tags_itl", [])),
                "contribuyeAlarm": analysis.get("contribuye_alarmismo", 0.0),
                "alertas": json.dumps(analysis.get("alertas", [])),
                "preguntaNoRespondida": analysis.get("pregunta_no_respondida"),
            },
            update={}
        )

        await prisma.tweet.update(
            where={"id": tweet.id},
            data={"analysisStatus": "done"}
        )

        # ─── Actualizar señales downstream ───────────────────
        # Actualizar Welford con contribuye_alarmismo
        from app.services.welford_tracker import tracker
        for tag in analysis.get("tags_itl", []):
            tracker.update(tag, analysis.get("contribuye_alarmismo", 0))

        logger.debug(f"[Analyzer] Tweet {tweet.id} analyzed: {analysis.get('impacto_potencial')}")

    except Exception as e:
        await prisma.tweet.update(
            where={"id": tweet.id},
            data={"analysisStatus": "error"}
        )
        logger.error(f"[Analyzer] Error analyzing tweet {tweet.id}: {e}")


def build_tweet_prompt(tweet, profile) -> str:
    return f"""
PERFIL DEL AUTOR:
- Username: @{profile.username}
- Nombre: {profile.displayName or profile.username}
- Categoría: {profile.category}
- Tier: {profile.tier}
- Orientación conocida: {profile.politicalLean or "No determinada"}
- ¿Es afiliado estatal?: {"Sí" if profile.isStateAffiliated else "No"}

TWEET A ANALIZAR:
"{tweet.rawContent}"

Fecha: {tweet.createdAt.strftime("%Y-%m-%d %H:%M UTC")}
Engagement: {tweet.likeCount} likes · {tweet.retweetCount} RTs · {tweet.replyCount} replies

[SCHEMA REQUERIDO como arriba]
"""
