# Extender calculate_itl() para incluir tweets

async def get_tweet_signals(country_code: str, ventana: timedelta) -> dict:
    """
    Extrae señales de tweets de perfiles del país en la ventana temporal.
    """
    since = datetime.utcnow() - ventana

    tweets = await prisma.tweet.find_many(
        where={
            "createdAt": {"gte": since},
            "analysisStatus": "done",
            "profile": {"country": country_code},
        },
        include={"analysis": True, "profile": True},
    )

    if not tweets:
        return {"tweet_alarm_score": 0, "declaraciones_oficiales": 0, "tweet_count": 0}

    # Score de alarmismo desde tweets (weight mayor si es tier S o A)
    alarm_scores = []
    for t in tweets:
        if t.analysis:
            weight = 2.0 if t.profile.tier in ("S", "A") else 1.0
            alarm_scores.append(t.analysis.contribuyeAlarm * weight)

    tweet_alarm = sum(alarm_scores) / len(alarm_scores) if alarm_scores else 0

    # Declaraciones oficiales en el período
    declaraciones = sum(1 for t in tweets if t.analysis and t.analysis.esDeclaracionOficial)

    return {
        "tweet_alarm_score": min(100, tweet_alarm * 100),
        "declaraciones_oficiales": declaraciones,
        "tweet_count": len(tweets),
        "impacto_critico_count": sum(
            1 for t in tweets if t.analysis and t.analysis.impactoPotencial == "critico"
        ),
    }


