    include: { analysis: true },
    orderBy: { createdAt: 'desc' },
    take: 10,
  });

  res.json({
    hasProfile: true,
    profile: {
      username: profile.username,
      displayName: profile.displayName,
      followersCount: profile.followersCount,
      verifiedType: profile.verifiedType,
    },
    tweets: tweets.map(normalizeTweetForFeed),
    stats: {
      total7d: tweets.length,
      avgAlarmismo: average(tweets.map(t => t.analysis?.scoreAlarmismo ?? 0)),
      declaracionesOficiales: tweets.filter(t => t.analysis?.esDeclaracionOficial).length,
    },
  });
});
